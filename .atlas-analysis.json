  "keyFeatures": [
    "Proof of Stake Voting (PoSV) consensus with 150 masternodes",
    "Near-zero transaction fees and 2-second block times",
    "TomoX decentralized exchange protocol",
    "TomoX lending and borrowing protocol",
    "TRC21 token standard for gasless transactions",
    "Full EVM compatibility for smart contracts",
    "Double validation and true randomization for security",
    "Masternode staking via smart contracts"
  ],
  "publicApiSurface": [
    "tomo - Main CLI entry point",
    "tomo account new - Create new account",
    "tomo account import - Import existing account",
    "tomo init - Initialize node with genesis",
    "tomo console - Interactive JavaScript console",
    "tomo attach - Attach to running node",
    "eth_* - Standard Ethereum JSON-RPC methods",
    "net_* - Network status RPC methods",
    "personal_* - Account management RPC methods",
    "debug_* - Debug and trace RPC methods",
    "HTTP RPC - JSON-RPC over HTTP",
    "WebSocket RPC - JSON-RPC over WebSocket",
    "IPC - Inter-process communication"
  ]
